# ====================================================
# TruthLens — Environment Variables
# Copy to .env.local — NEVER commit .env.local
# ====================================================

# ── AI Provider (one required) ──────────────────────
# OpenRouter — free models available
# Get key: https://openrouter.ai → Keys
OPENROUTER_API_KEY=sk-or-v1-...

# Optional: override the default free model
# OPENROUTER_MODEL=openrouter/auto

# Groq — fast free tier (fallback if no OpenRouter)
# Get key: https://console.groq.com
GROQ_API_KEY=gsk_...

# ── News APIs (optional, improves evidence) ─────────
# Free 100 req/day: https://newsapi.org
NEWS_API_KEY=

# Free 100 req/day: https://gnews.io
GNEWS_API_KEY=

# ── Supabase (enables auth + user history) ──────────
# Get from: supabase.com → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJh...

# ── Admin ───────────────────────────────────────────
NEXT_PUBLIC_ADMIN_KEY=change-this-in-production

# ── App ─────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── AI Provider (new unified config, optional) ──────────────────────
# These override individual keys above if set
# AI_PROVIDER=openrouter
# AI_MODEL=meta-llama/llama-3.1-8b-instruct:free
# AI_API_KEY=sk-or-v1-...
#
# Switch to Groq:
# AI_PROVIDER=groq
# AI_MODEL=llama-3.1-8b-instant
# AI_API_KEY=gsk_...
